---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const tags = [...new Set(posts.flatMap(p => p.data.tags ?? []))];
  return tags.map(tag => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter(p => p.data.tags?.includes(tag))
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;

function slug(id: string) { return id.replace(/\.md$/, ''); }

function formatDate(d: Date) {
  return d.toLocaleDateString('en-IE', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<Base title={`#${tag} — Writing — Matteo Stara`} description={`Posts tagged ${tag}.`}>
  <div class="tag-header">
    <a href="/writing" class="tag-back">← writing</a>
    <h2>#{tag}</h2>
  </div>
  <div class="post-list">
    {posts.map(post => (
      <div class="post-item">
        <div class="post-item-header">
          <a href={`/writing/${slug(post.id)}`}>{post.data.title}</a>
          <span class="post-date">{formatDate(post.data.date)}</span>
        </div>
        <p class="post-description">{post.data.description}</p>
      </div>
    ))}
  </div>
</Base>
