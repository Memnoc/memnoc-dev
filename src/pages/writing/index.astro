  compilers: `<svg width="120" height="80" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="80" fill="#2a273f"/><rect width="120" height="10" fill="#393552"/><rect x="8" y="3" width="6" height="4" rx="1" fill="#9ccfd8" opacity="0.7"/><rect x="16" y="3" width="12" height="4" rx="1" fill="#6e6a86" opacity="0.5"/><rect x="44" y="16" width="32" height="7" rx="3" fill="#9ccfd8" opacity="0.85"/><line x1="60" y1="23" x2="28" y2="35" stroke="#6e6a86" stroke-width="1" opacity="0.5"/><line x1="60" y1="23" x2="92" y2="35" stroke="#6e6a86" stroke-width="1" opacity="0.5"/><rect x="12" y="35" width="32" height="7" rx="3" fill="#c4a7e7" opacity="0.8"/><rect x="76" y="35" width="32" height="7" rx="3" fill="#eb6f92" opacity="0.8"/><line x1="28" y1="42" x2="18" y2="54" stroke="#6e6a86" stroke-width="1" opacity="0.4"/><line x1="28" y1="42" x2="38" y2="54" stroke="#6e6a86" stroke-width="1" opacity="0.4"/><line x1="92" y1="42" x2="82" y2="54" stroke="#6e6a86" stroke-width="1" opacity="0.4"/><line x1="92" y1="42" x2="102" y2="54" stroke="#6e6a86" stroke-width="1" opacity="0.4"/><rect x="8" y="54" width="20" height="6" rx="2" fill="#f6c177" opacity="0.7"/><rect x="30" y="54" width="20" height="6" rx="2" fill="#f6c177" opacity="0.7"/><rect x="70" y="54" width="20" height="6" rx="2" fill="#ea9a97" opacity="0.7"/><rect x="92" y="54" width="20" height="6" rx="2" fill="#ea9a97" opacity="0.7"/></svg>`,

  // Default — abstract Rosé Pine code lines
  default: `<svg width="120" height="80" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="80" fill="#2a273f"/><rect width="120" height="10" fill="#393552"/><rect x="8" y="16" width="40" height="4" rx="2" fill="#6e6a86" opacity="0.5"/><rect x="52" y="16" width="24" height="4" rx="2" fill="#c4a7e7" opacity="0.5"/><rect x="8" y="25" width="18" height="4" rx="2" fill="#3e8fb0" opacity="0.7"/><rect x="30" y="25" width="32" height="4" rx="2" fill="#6e6a86" opacity="0.4"/><rect x="16" y="34" width="28" height="4" rx="2" fill="#6e6a86" opacity="0.4"/><rect x="48" y="34" width="44" height="4" rx="2" fill="#9ccfd8" opacity="0.5"/><rect x="16" y="43" width="14" height="4" rx="2" fill="#3e8fb0" opacity="0.6"/><rect x="34" y="43" width="20" height="4" rx="2" fill="#6e6a86" opacity="0.4"/><rect x="58" y="43" width="30" height="4" rx="2" fill="#f6c177" opacity="0.4"/><rect x="8" y="52" width="36" height="4" rx="2" fill="#6e6a86" opacity="0.3"/><rect x="48" y="52" width="18" height="4" rx="2" fill="#c4a7e7" opacity="0.4"/><rect x="16" y="61" width="24" height="4" rx="2" fill="#6e6a86" opacity="0.3"/><rect x="44" y="61" width="38" height="4" rx="2" fill="#eb6f92" opacity="0.3"/></svg>`,
};

function placeholderSvg(tags: string[]): string {
  const lang = tags.map(t => TAG_TO_LANG[t]).find(Boolean) ?? 'default';
  const svg = LANG_SVGS[lang] ?? LANG_SVGS.default;
  return `data:image/svg+xml,${encodeURIComponent(svg)}`;
}

function thumbFor(post: { data: { image?: string; tags: string[]; title: string }; body?: string }): string {
  return post.data.image ?? firstImage(post.body ?? '') ?? placeholderSvg(post.data.tags);
}
---

<Base title="Writing — Matteo Stara (memnoc)" description="Notes on compilers, systems software, and language implementation.">
  <h2>Writing</h2>
  <div class="post-list">
    {posts.map((post) => (
      <div class="post-item">
        <div class="post-meta-line">
          <span class="post-date">{formatDate(post.data.date)}</span>
          <span class="post-meta-sep">·</span>
          <span class="post-readtime">{readTime(post.body ?? '')}</span>
          {post.data.tags.length > 0 && (
            <>
              <span class="post-meta-sep">·</span>
              <span class="post-tags-inline">
                {post.data.tags.map(t => (
                  <a href={`/writing/tag/${t}`} class="tag post-tag">#{t}</a>
                ))}
              </span>
            </>
          )}
        </div>
        <div class="post-body-row">
          <div class="post-text">
            <a href={`/writing/${slug(post.id)}`} class="post-title-link">{post.data.title}</a>
            <p class="post-description">{post.data.description}</p>
          </div>
          <a href={`/writing/${slug(post.id)}`} class="post-thumb-link">
            <img src={thumbFor(post)} alt="" class="post-thumb" loading="lazy" />
          </a>
        </div>
      </div>
    ))}
  </div>
</Base>
