---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function slug(id: string) { return id.replace(/\.md$/, ''); }

function formatDate(d: Date) {
  return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }).toUpperCase();
}

function readTime(body: string) {
  const words = body.trim().split(/\s+/).length;
  return `${Math.max(1, Math.round(words / 200))} MIN READ`;
}

function firstImage(body: string): string | null {
  const m = body.match(/!\[.*?\]\((.+?)\)/);
  return m ? m[1] : null;
}

const TAG_TO_LANG: Record<string, string> = {
  c_language: 'c', c: 'c',
  rust: 'rust',
  python: 'python', py: 'python',
  javascript: 'javascript', js: 'javascript',
  typescript: 'typescript', ts: 'typescript',
  go: 'go', golang: 'go',
  haskell: 'haskell',
  ocaml: 'ocaml',
  zig: 'zig',
  compilers: 'compilers', crafting_interpreters: 'compilers',
  interpreters: 'compilers', parsers: 'compilers', llvm: 'compilers',
};

