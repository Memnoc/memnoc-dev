---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function slug(id: string) { return id.replace(/\.md$/, ''); }

function formatDate(d: Date) {
  return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }).toUpperCase();
}

function readTime(body: string) {
  const words = body.trim().split(/\s+/).length;
  return `${Math.max(1, Math.round(words / 200))} MIN READ`;
}

function firstImage(body: string): string | null {
  const m = body.match(/!\[.*?\]\((.+?)\)/);
  return m ? m[1] : null;
}

function placeholderSvg(index: number): string {
  const variants = [
    `<svg width="120" height="80" xmlns="http://www.w3.org/2000/svg"><defs><linearGradient id="g" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#eb6f92"/><stop offset="100%" stop-color="#3e8fb0"/></linearGradient></defs><rect width="120" height="80" fill="url(#g)"/></svg>`,
    `<svg width="120" height="80" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="80" fill="#286983"/><path d="M0 20h120M0 40h120M0 60h120M30 0v80M60 0v80M90 0v80" stroke="#9ccfd8" stroke-width="0.5" opacity="0.5"/></svg>`,
    `<svg width="120" height="80" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="80" fill="#44415a"/><circle cx="60" cy="40" r="38" fill="none" stroke="#c4a7e7" stroke-width="1" opacity="0.4"/><circle cx="60" cy="40" r="25" fill="none" stroke="#c4a7e7" stroke-width="1" opacity="0.5"/><circle cx="60" cy="40" r="12" fill="#c4a7e7" opacity="0.3"/></svg>`,
    `<svg width="120" height="80" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="80" fill="#2a273f"/><line x1="0" y1="80" x2="120" y2="0" stroke="#f6c177" stroke-width="40" opacity="0.1"/><line x1="-30" y1="80" x2="90" y2="0" stroke="#f6c177" stroke-width="20" opacity="0.08"/><line x1="30" y1="80" x2="150" y2="0" stroke="#f6c177" stroke-width="20" opacity="0.08"/></svg>`,
    `<svg width="120" height="80" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="80" fill="#393552"/><circle cx="120" cy="0" r="90" fill="none" stroke="#9ccfd8" stroke-width="1.5" opacity="0.35"/><circle cx="120" cy="0" r="60" fill="none" stroke="#9ccfd8" stroke-width="1.5" opacity="0.3"/><circle cx="120" cy="0" r="30" fill="#9ccfd8" opacity="0.12"/></svg>`,
  ];
  return `data:image/svg+xml,${encodeURIComponent(variants[index % variants.length])}`;
}

function thumbFor(post: { data: { image?: string; tags: string[]; title: string }; body?: string }, index: number): string {
  return post.data.image ?? firstImage(post.body ?? '') ?? placeholderSvg(index);
}
---

<Base title="Writing — Matteo Stara (memnoc)" description="Notes on compilers, systems software, and language implementation.">
  <h2>Writing</h2>
  <div class="post-list">
    {posts.map((post, i) => (
      <div class="post-item">
        <div class="post-meta-line">
          <span class="post-date">{formatDate(post.data.date)}</span>
          <span class="post-meta-sep">·</span>
          <span class="post-readtime">{readTime(post.body ?? '')}</span>
          {post.data.tags.length > 0 && (
            <>
              <span class="post-meta-sep">·</span>
              <span class="post-tags-inline">
                {post.data.tags.map(t => (
                  <a href={`/writing/tag/${t}`} class="tag post-tag">#{t}</a>
                ))}
              </span>
            </>
          )}
        </div>
        <div class="post-body-row">
          <div class="post-text">
            <a href={`/writing/${slug(post.id)}`} class="post-title-link">{post.data.title}</a>
            <p class="post-description">{post.data.description}</p>
          </div>
          <a href={`/writing/${slug(post.id)}`} class="post-thumb-link">
            <img src={thumbFor(post, i)} alt="" class="post-thumb" loading="lazy" />
          </a>
        </div>
      </div>
    ))}
  </div>
</Base>
