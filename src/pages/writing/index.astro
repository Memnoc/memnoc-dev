---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function slug(id: string) { return id.replace(/\.md$/, ''); }

function formatDate(d: Date) {
  return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }).toUpperCase();
}

function readTime(body: string) {
  const words = body.trim().split(/\s+/).length;
  return `${Math.max(1, Math.round(words / 200))} MIN READ`;
}

function firstImage(body: string): string | null {
  const m = body.match(/!\[.*?\]\((.+?)\)/);
  return m ? m[1] : null;
}

function fallbackImage(tags: string[], title: string): string {
  const keywords = tags.length > 0 ? tags.slice(0, 2).join(',') : title.split(' ').slice(0, 2).join(',');
  return `https://loremflickr.com/400/300/${encodeURIComponent(keywords)}`;
}

function thumbFor(post: { data: { image?: string; tags: string[]; title: string }; body?: string }): { url: string; credit: boolean } {
  const manual = post.data.image ?? firstImage(post.body ?? '');
  if (manual) return { url: manual, credit: false };
  return { url: fallbackImage(post.data.tags, post.data.title), credit: true };
}
---

<Base title="Writing — Matteo Stara (memnoc)" description="Notes on compilers, systems software, and language implementation.">
  <h2>Writing</h2>
  <div class="post-list">
    {posts.map(post => (
      <div class="post-item">
        <div class="post-meta-line">
          <span class="post-date">{formatDate(post.data.date)}</span>
          <span class="post-meta-sep">·</span>
          <span class="post-readtime">{readTime(post.body ?? '')}</span>
          {post.data.tags.length > 0 && (
            <>
              <span class="post-meta-sep">·</span>
              <span class="post-tags-inline">
                {post.data.tags.map(t => (
                  <a href={`/writing/tag/${t}`} class="tag post-tag">#{t}</a>
                ))}
              </span>
            </>
          )}
        </div>
        <div class="post-body-row">
          <div class="post-text">
            <a href={`/writing/${slug(post.id)}`} class="post-title-link">{post.data.title}</a>
            <p class="post-description">{post.data.description}</p>
          </div>
          {(() => { const t = thumbFor(post); return (
            <div class="post-thumb-wrap">
              <a href={`/writing/${slug(post.id)}`} class="post-thumb-link">
                <img src={t.url} alt="" class="post-thumb" loading="lazy" />
              </a>
              {t.credit && <a href="https://flickr.com/creativecommons" target="_blank" rel="noopener" class="post-thumb-credit">Photo: Flickr CC</a>}
            </div>
          ); })()}
        </div>
      </div>
    ))}
  </div>
</Base>
