---
import Base from '../layouts/Base.astro';
import DemoCarousel from '../components/DemoCarousel.tsx';

const projects = [
  {
    name: 'r_command_line',
    blurb: 'CLI tool that generates commit messages. Finished; needs a revisit.',
    langs: ['Rust'],
    status: 'Original',
    url: 'https://github.com/Memnoc/r_command_line',
  },
  {
    name: 'StarScript',
    blurb: 'Lox-flavored interpreter in C. Following Crafting Interpreters but extended — named grammar rules, custom error handling, going past the book.',
    langs: ['C'],
    status: 'Personalized from project',
    url: 'https://github.com/Memnoc/StarScript',
  },
  {
    name: 'BYOL',
    blurb: 'Build Your Own Lisp — personalizing the tutorial, adding extensions as I understand each concept.',
    langs: ['C'],
    status: 'WIP',
    url: 'https://github.com/Memnoc/BYOL',
  },
  {
    name: 'shell',
    blurb: 'POSIX shell in Rust. Codecrafters challenge, extended beyond the spec — builtins, PATH resolution, REPL loop.',
    langs: ['Rust'],
    status: 'WIP',
    url: 'https://github.com/Memnoc/codecrafters-shell-rust',
  },
] as const;

type StatusKey = typeof projects[number]['status'];

const statusClass: Record<StatusKey, string> = {
  'Original':            'status-original',
  'Personalized from project': 'status-personalized-from-project',
  'WIP':                 'status-wip',
};
---

<Base title="Matteo Stara (memnoc)">
  <section class="profile-header" id="contact">
    <img src="/Matteo-profile-modified.png" alt="Matteo Stara" class="profile-img" />
    <div class="profile-info">
      <h1 class="name">Matteo Stara <span class="handle">(memnoc)</span></h1>
      <p class="title">Systems programmer · C · Rust</p>
      <div class="contact-row">
        <a href="mailto:memnochmod@gmail.com" class="contact-email">memnochmod@gmail.com</a>
        <div class="social-icons">
          <a href="https://github.com/Memnoc" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
            <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
            </svg>
          </a>
          <a href="https://linkedin.com/in/matteostara" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146zm4.943 12.248V6.169H2.542v7.225h2.401zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248-.822 0-1.359.54-1.359 1.248 0 .694.521 1.248 1.327 1.248h.016zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016a5.54 5.54 0 0 1 .016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225h2.4z"/>
            </svg>
          </a>
          <a href="https://www.artstation.com/starart" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="ArtStation">
            <svg width="15" height="15" viewBox="0 0 16 14" fill="currentColor" aria-hidden="true">
              <path d="M0 13.985l6-10.97 1.032 1.864-4.966 9.106H0zm10.982-10.977L5 13.985h5.982l.967-1.707h3.077L16 13.985 10.982 3.008z"/>
            </svg>
          </a>
          <a href="https://labotteghina.gallery" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="La Botteghina">
            <svg width="15" height="15" viewBox="0 0 64 64" aria-hidden="true">
              <text x="32" y="50" font-family="Georgia, 'Times New Roman', serif" font-size="52" fill="currentColor" text-anchor="middle" font-style="italic">B</text>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="hero">
    <p class="oneliner">I write systems software in C and Rust. Compilers, mostly.</p>
    <p class="current">Currently: an interpreter and notes from Crafting Interpreters.</p>
  </section>

  <section class="demo-section">
    <DemoCarousel client:only="react" />
  </section>

  <section class="built">
    <h2>Built</h2>
    <div class="project-list">
      {projects.map(p => (
        <div class="project-card">
          <div class="project-header">
            <a href={p.url} target="_blank" rel="noopener noreferrer">{p.name}</a>
            <span class={`status ${statusClass[p.status]}`}>{p.status.toLowerCase()}</span>
          </div>
          <p class="blurb">{p.blurb}</p>
          <div class="lang-tags">
            {p.langs.map(l => <span class="tag">{l}</span>)}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="studying">
    <h2>Currently</h2>
    <p class="studying-text">
      <em>Crafting Interpreters</em> — working through closures and the resolver pass.
      Variable resolution across scope boundaries took longer than expected;
      the way the resolver and interpreter share state is subtle.
    </p>
    <p class="studying-text">
      Also rereading <em>Build Your Own Lisp</em> with fresh eyes after the StarScript work.
    </p>
  </section>

</Base>
