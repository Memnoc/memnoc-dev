---
import '../styles/global.css';

declare const __GIT_HASH__: string;

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
}

const {
  title = 'Matteo Stara (memnoc)',
  description = 'Systems software engineer. C and Rust. Compilers.',
  currentPath = Astro.url.pathname,
} = Astro.props;

const gitHash = __GIT_HASH__;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <!-- Apply theme before first paint to prevent flash -->
    <script is:inline>
      (function () {
        var saved = localStorage.getItem('rp-theme');
        if (saved === 'moon' || saved === 'dawn') {
          document.documentElement.setAttribute('data-theme', saved);
        } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          document.documentElement.setAttribute('data-theme', 'moon');
        } else {
          document.documentElement.setAttribute('data-theme', 'dawn');
        }
      })();
    </script>
  </head>
  <body>
    <nav class="site-nav">
      <div class="nav-status">
        <span id="utc-clock" class="nav-clock" aria-label="Current UTC time"></span>
        <a
          href={`https://github.com/Memnoc/matteostara-com/commit/${gitHash}`}
          target="_blank"
          rel="noopener noreferrer"
          class="build-hash"
        >build: {gitHash}</a>
      </div>
      <div class="nav-links">
        <a href="/" class:list={[{ active: currentPath === '/' }]}>home</a>
        <a href="/about" class:list={[{ active: currentPath === '/about' }]}>about</a>
        <a href="/writing" class:list={[{ active: currentPath.startsWith('/writing') }]}>writing</a>
      </div>
      <button id="theme-toggle" aria-label="Toggle theme">
        <svg class="icon-dawn" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"/>
          <line x1="12" y1="2" x2="12" y2="5"/>
          <line x1="12" y1="19" x2="12" y2="22"/>
          <line x1="2" y1="12" x2="5" y2="12"/>
          <line x1="19" y1="12" x2="22" y2="12"/>
          <line x1="4.22" y1="4.22" x2="6.34" y2="6.34"/>
          <line x1="17.66" y1="17.66" x2="19.78" y2="19.78"/>
          <line x1="4.22" y1="19.78" x2="6.34" y2="17.66"/>
          <line x1="17.66" y1="6.34" x2="19.78" y2="4.22"/>
        </svg>
        <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
    </nav>
    <main>
      <slot />
    </main>

    <script>
      const btn = document.getElementById('theme-toggle');

      btn?.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme');
        const next = current === 'moon' ? 'dawn' : 'moon';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('rp-theme', next);
      });

      const clock = document.getElementById('utc-clock');
      function tick() {
        if (clock) clock.textContent = new Date().toISOString().replace(/\.\d{3}Z$/, 'Z');
      }
      tick();
      setInterval(tick, 1000);
    </script>
  </body>
</html>
